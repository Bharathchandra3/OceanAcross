# Conversation Evaluation Benchmark - Environment Configuration

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# LLM Configuration (for future integration)
LLM_MODEL=llama2-7b
LLM_PROVIDER=ollama
LLM_HOST=http://localhost:11434
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7

# Database
DATABASE_URL=sqlite:///./data/evaluation.db
DATABASE_POOL_SIZE=5

# Evaluation Settings
MIN_SCORE=1
MAX_SCORE=5
DEFAULT_BATCH_SIZE=50
EVALUATION_TIMEOUT=300

# File Paths
DATA_DIR=./data
OUTPUT_DIR=./output
FACETS_FILE=./data/facets_processed.json
CONVERSATIONS_FILE=./data/conversations/sample_conversations.json

# Caching
CACHE_ENABLED=true
CACHE_TTL=3600
REDIS_URL=redis://localhost:6379

# Feature Flags
ENABLE_BATCH_EVALUATION=true
ENABLE_CONFIDENCE_SCORING=true
ENABLE_RELATIONSHIP_TRACKING=true

# Performance
MAX_CONCURRENT_EVALUATIONS=5
BATCH_TIMEOUT=60
